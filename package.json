{
  "name": "jumbo-ocr",
  "version": "1.0.0",
  "description": "OCR Service for Jumbo Electronics",
  "main": "srv/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node srv/server.js",
    "watch": "npx --no-install cds watch",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "watch-ocr-trigger": "npx --no-install cds watch --open com.jumbo.ocr.ocrtrigger/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy jumbo-ocr --delete-services --delete-service-keys --delete-service-brokers",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "dependencies": {
    "@cap-js/sqlite": "^2.2.0",
    "@sap-cloud-sdk/connectivity": "^3.0.0",
    "@sap-cloud-sdk/http-client": "^3.0.0",
    "@sap/cds": "9.8.3",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@sap/cds-dk": "9.8.2",
    "cds-plugin-ui5": "^0.13.6",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "overrides": {
    "@sap/cds-dk": {
      "@sap/cds": "9.8.3"
    }
  },
  "cds": {
    "requires": {
      "auth": "dummy",
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": ":memory:"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/ocr-trigger"
  ]
}