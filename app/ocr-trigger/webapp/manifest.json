{
  "_version": "1.83.0",
  "sap.app": {
    "id": "com.jumbo.ocr.ocrtrigger",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.21.0",
      "toolsId": "ed36f5a2-7e22-4b69-9f20-6c6ca8780b06"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/ocr/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.jumbo.ocr.ocrtrigger.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "OCRLogsList",
          "target": "OCRLogsList"
        },
        {
          "pattern": "OCRLogs({key}):?query:",
          "name": "OCRLogsObjectPage",
          "target": "OCRLogsObjectPage"
        }
      ],
      "targets": {
        "OCRLogsList": {
          "type": "Component",
          "id": "OCRLogsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/OCRLogs",
              "variantManagement": "Page",
              "navigation": {
                "OCRLogs": {
                  "detail": {
                    "route": "OCRLogsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
"OCRLogsObjectPage": {
          "type": "Component",
          "id": "OCRLogsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "contextPath": "/OCRLogs",
              "editableHeaderContent": false,
              "content": {
                "header": {
                  "actions": {
                    "editDetails": {
                      "press": "com.jumbo.ocr.ocrtrigger.ext.ObjectPageExt.onEditPress",
                      "visible": true,
                      "enabled": true,
                      "text": "Edit"
                    }
                  }
                },
                "body": {
                  "sections": {
                    "editSection": {
                      "template": "com.jumbo.ocr.ocrtrigger.ext.EditSection",
                      "title": "Actions",
                      "position": {
                        "placement": "Before",
                        "anchor": "GeneralInfo"
                      }
                    }
                  }
                }
              },
              "navigation": {},
              "controlConfiguration": {
                "Items/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "selectionMode": "Single"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}